@CODE:
<form id="eFiltr" class="eFiltr eFiltr_form" action="[+url+]" method="[+form_method+]">
    <div id="eFiltr_info">НАЙДЕНО:
        <span id="eFiltr_info_cnt">[+total+]</span>
        <span id="eFiltr_info_cnt_ending">[+total_endings+]</span>
    </div>
    [+wrapper+]
    <div class="eFiltr_form_result">[+total+]</div>
    <div class="eFiltr_btn_wrapper">
        <input type="submit" class="eFiltr_btn" value="[+btn_text+]">
    </div>
</form>